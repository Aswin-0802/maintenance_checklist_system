PORT=5000
NODE_ENV=development
# Comma-separated list of allowed frontend origins (no trailing slash)
CLIENT_URL=http://localhost:5173
JWT_SECRET=change-this-to-a-long-secret
JWT_EXPIRES_IN=1d
# Postgres connection string. Example (Render): postgresql://user:pass@host:5432/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/maintenance_checklist
